{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "scripts/**",
      "games/3-over-match/data/archive/**"
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/admin",
        "destination": "/admin/index.html"
      },
      {
        "source": "/admin/**",
        "destination": "/admin/index.html"
      },
      {
        "source": "/admin-v2",
        "destination": "/admin-v2/index.html"
      },
      {
        "source": "/admin-v2/index.html",
        "destination": "/admin-v2/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
